{
  "name": "bestapp-forum",
  "version": "1.0.0",
  "description": "BestApp Forum - A Mobilism-like community platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node utils/seed.js",
    "reset-admin": "node utils/reset-admin.js",
    "client:install": "cd client && npm install",
    "client:build": "cd client && npm run build",
    "build": "npm run client:install && npm run client:build",
    "heroku-postbuild": "npm run build",
    "postinstall": "bash build-client.sh"
  },
  "engines": {
    "node": "20.x"
  },
  "keywords": [
    "forum",
    "community",
    "mobilism",
    "mern"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.1",
    "mongoose-paginate-v2": "^1.8.2",
    "multer": "^1.4.5-lts.1",
    "slugify": "^1.6.6",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.3"
  }
}
